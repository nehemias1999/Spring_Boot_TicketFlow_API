# -------------------------------------------------------
# TicketFlow — environment variables template
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# -------------------------------------------------------

# ── JWT (must be identical across all services) ────────
# Minimum 32 characters, change in every environment
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRATION_MS=86400000

# ── Internal service-to-service secret ─────────────────
# Used by ticket-service when calling event-service internal endpoints
INTERNAL_API_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# ── MySQL ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
DB_USERNAME=ticketflow
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# ── RabbitMQ ───────────────────────────────────────────
RABBITMQ_USERNAME=ticketflow
RABBITMQ_PASSWORD=REPLACE_WITH_STRONG_RABBITMQ_PASSWORD

# ── Mail (production SMTP) ─────────────────────────────
# For local dev, leave these blank — MailHog handles it
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@ticketflow.com
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false

# ── CORS ───────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Observability ──────────────────────────────────────
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans

# ── JPA / debug ────────────────────────────────────────
SHOW_SQL=false

# ── Actuator ───────────────────────────────────────────
# In production use: health,info
# In development you can add: metrics,prometheus
MANAGEMENT_ENDPOINTS_INCLUDE=health,info
MANAGEMENT_HEALTH_SHOW_DETAILS=when-authorized
